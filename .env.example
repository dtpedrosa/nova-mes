# Nova Pharma MES — environment variables
#
# Copy to `.env` and fill in real values for a Dynatrace-connected run.
# `.env` is gitignored, so your real token never gets committed.
# Omit everything for a fully-local run (telemetry logs to stdout / the collector's
# debug exporter, and the app still works end to end).

# ---- Dynatrace OTLP ingest (used by the OpenTelemetry Collector) ----
# The collector holds the token and forwards app + browser telemetry to the tenant.
DT_ENDPOINT=https://ENV_ID.live.dynatrace.com/api/v2/otlp
DT_API_TOKEN=dt0c01.XXXXXXXXXXXXXXXXXXXXXXXX
# Token scopes required: openTelemetryTrace.ingest, metrics.ingest, logs.ingest, bizevents.ingest

# ---- App -> collector OTLP (set automatically in docker-compose / k8s) ----
# Point the services and the browser OTLP proxy at the collector, not the tenant.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
RUM_OTLP_TARGET=http://otel-collector:4318

# ---- Business events (direct to tenant API; separate from OTLP) ----
# Optional locally. If unset, bizevents print as structured JSON to stdout.
DT_TENANT_URL=https://ENV_ID.live.dynatrace.com
# DT_API_TOKEN is reused for bizevents; needs the bizevents.ingest scope.

# ---- Resource attributes ----
NOVA_SITE=Northgate
DEPLOY_ENV=demo

# ---- Load generator ----
TARGET=http://mes-web:4000
RPS=2
RELEASE_MIX=0.4
